{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "dish.schema.json",
    "title": "Dish",
    "description": "A dish served on the menu, composed of ingredient components",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Unique identifier in UPPER_SNAKE_CASE",
            "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "name": {
            "type": "string",
            "description": "Display name of the dish"
        },
        "description": {
            "type": "string",
            "description": "Short description of the dish"
        },
        "price": {
            "type": "number",
            "description": "Menu price in dollars",
            "minimum": 0
        },
        "available": {
            "type": "boolean",
            "description": "Whether the dish is currently available"
        },
        "components": {
            "type": "array",
            "description": "List of ingredient IDs that make up this dish",
            "items": {
                "type": "string"
            }
        }
    },
    "required": ["id", "name", "description", "price", "available", "components"],
    "additionalProperties": false
}
