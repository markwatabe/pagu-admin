---
import Layout from '../layouts/Layout.astro';
import FeatureCard from '../components/FeatureCard.astro';

const features = [
  {
    icon: '⚡',
    title: 'Blazing Fast',
    description: 'Built with Astro\'s island architecture for zero JavaScript by default and optimal performance.',
  },
  {
    icon: '🎨',
    title: 'Beautiful Design',
    description: 'Styled with Tailwind CSS v4 for a modern, responsive UI that looks great on every device.',
  },
  {
    icon: '🔒',
    title: 'Type Safe',
    description: 'Written in strict TypeScript so you catch errors at compile time, not at runtime.',
  },
  {
    icon: '📦',
    title: 'Easy to Deploy',
    description: 'Deploy anywhere — Vercel, Netlify, Cloudflare Pages, or any static host with zero config.',
  },
  {
    icon: '🧩',
    title: 'Component Driven',
    description: 'Compose UIs from reusable Astro components with scoped styles and typed props.',
  },
  {
    icon: '🌐',
    title: 'SEO Ready',
    description: 'Static HTML output means search engines can crawl and index every page with no extra work.',
  },
] satisfies { icon: string; title: string; description: string }[];
---

<Layout title="Pagu — Modern Web Starter">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-b from-indigo-50 to-white px-6 py-24 text-center">
    <div class="mx-auto max-w-3xl">
      <span class="mb-4 inline-block rounded-full bg-indigo-100 px-4 py-1 text-sm font-medium text-indigo-700">
        Astro + TypeScript + Tailwind CSS
      </span>
      <h1 class="mt-4 text-5xl font-extrabold tracking-tight text-gray-900 sm:text-6xl">
        Build fast websites,<br />
        <span class="text-indigo-600">ship with confidence.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg text-gray-500">
        A modern starter template combining Astro's speed, TypeScript's safety, and Tailwind's flexibility.
        Everything you need to build and ship a great website.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a
          href="#features"
          class="rounded-full bg-indigo-600 px-8 py-3 font-semibold text-white shadow-md transition hover:bg-indigo-700"
        >
          Explore features
        </a>
        <a
          href="https://docs.astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full border border-gray-200 bg-white px-8 py-3 font-semibold text-gray-700 shadow-sm transition hover:border-indigo-300 hover:text-indigo-600"
        >
          Read the docs
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Everything you need</h2>
        <p class="mt-4 text-gray-500">A solid foundation so you can focus on building your product.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((feature) => (
          <FeatureCard {...feature} />
        ))}
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="bg-gray-50 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid items-center gap-16 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
            Built on the best tools available
          </h2>
          <p class="mt-6 text-gray-500 leading-relaxed">
            This starter brings together three of the most productive tools in modern web development.
            Astro handles rendering, TypeScript keeps your code correct, and Tailwind makes styling fast and consistent.
          </p>
          <ul class="mt-8 space-y-4">
            {[
              ['Astro 5', 'Content-first framework with zero JS by default'],
              ['TypeScript (strict)', 'Full type safety across all components and pages'],
              ['Tailwind CSS v4', 'Utility-first CSS with a next-gen engine'],
            ].map(([name, desc]) => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-indigo-600 text-xs font-bold">✓</span>
                <div>
                  <span class="font-semibold text-gray-900">{name}</span>
                  <span class="text-gray-500"> — {desc}</span>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-2xl bg-indigo-600 p-10 text-white shadow-xl">
          <p class="text-sm font-semibold uppercase tracking-widest text-indigo-200">Tech stack</p>
          <div class="mt-6 space-y-4">
            {[
              { label: 'Framework', value: 'Astro 5' },
              { label: 'Language', value: 'TypeScript (strict)' },
              { label: 'Styling', value: 'Tailwind CSS v4' },
              { label: 'Rendering', value: 'Static (SSG)' },
              { label: 'Deploy', value: 'Any static host' },
            ].map(({ label, value }) => (
              <div class="flex justify-between border-b border-indigo-500 pb-4 last:border-0 last:pb-0">
                <span class="text-indigo-200">{label}</span>
                <span class="font-semibold">{value}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact / CTA -->
  <section id="contact" class="px-6 py-24">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Ready to get started?</h2>
      <p class="mt-4 text-gray-500">Clone the repo, run the dev server, and ship something great.</p>
      <div class="mt-8 rounded-2xl bg-gray-900 p-6 text-left font-mono text-sm text-gray-300 shadow-lg">
        <p><span class="text-gray-500">$</span> <span class="text-green-400">npm</span> run dev</p>
      </div>
      <p class="mt-6 text-sm text-gray-400">
        Questions? Reach out at{' '}
        <a href="mailto:hello@example.com" class="text-indigo-600 underline underline-offset-2 hover:text-indigo-700">
          hello@example.com
        </a>
      </p>
    </div>
  </section>
</Layout>
