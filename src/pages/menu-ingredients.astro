---
import Layout from '../layouts/Layout.astro';
import { getMenuItemsWithIngredients } from '../queries/menuItemsWithIngredients';

const items = await getMenuItemsWithIngredients();
const sections = [...new Set(items.map((i) => i.section))];

function formatPrice(cents: number) {
  return (cents / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' });
}
---

<Layout title="Menu Ingredients — Pagu" description="Menu items and their ingredients">
  <section class="mx-auto max-w-5xl px-6 py-16">
    <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900">Menu Ingredients</h1>
      <p class="mt-1 text-gray-500">{items.length} items across {sections.length} sections</p>
    </div>

    <div class="space-y-10">
      {sections.map((section) => {
        const sectionItems = items.filter((i) => i.section === section);
        return (
          <div>
            <h2 class="mb-4 text-lg font-semibold text-gray-700">{section}</h2>
            <div class="space-y-3">
              {sectionItems.map((item) => (
                <div class="overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm">
                  <div class="flex items-baseline justify-between px-6 py-4 border-b border-gray-50">
                    <div>
                      <span class="font-semibold text-gray-900">{item.name}</span>
                      {item.description && (
                        <span class="ml-2 text-sm text-gray-400">{item.description}</span>
                      )}
                    </div>
                    <span class="ml-4 shrink-0 text-sm font-medium text-gray-700">{formatPrice(item.price)}</span>
                  </div>
                  <div class="px-6 py-3">
                    {item.ingredients.length === 0 ? (
                      <p class="text-sm text-gray-400 italic">No ingredients listed</p>
                    ) : (
                      <ul class="flex flex-wrap gap-2">
                        {item.ingredients.map((ing) => (
                          <li class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-3 py-1 text-xs text-gray-700">
                            {ing.name}
                            {(ing.amount || ing.measuredUnit) && (
                              <span class="text-gray-400">
                                {ing.amount}{ing.measuredUnit ? ` ${ing.measuredUnit}` : ''}
                              </span>
                            )}
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</Layout>
