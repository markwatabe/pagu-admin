---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition hover:shadow-md">
  <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-indigo-50 text-2xl">
    {icon}
  </div>
  <h3 class="mb-2 text-lg font-semibold text-gray-900">{title}</h3>
  <p class="text-gray-500 leading-relaxed">{description}</p>
</div>
